# Enforce LF line endings for all text files in this repository.
# Keeps line endings consistent across platforms and avoids CRLF churn.

# Default: normalize all text files to LF on commit
* text=auto eol=lf

# --- Source code ---
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.vue       text eol=lf

# --- Config / markup ---
*.json      text eol=lf
*.jsonc     text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf

# --- Binary: never touch line endings ---
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.pdf       binary
*.zip       binary
*.gz        binary
