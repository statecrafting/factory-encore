{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "entity-model.schema.json",
  "title": "Entity Model - Stage 1 Output",
  "description": "Every noun that represents a data object the system must track, extracted from business documents.",
  "type": "object",
  "required": ["entities"],
  "additionalProperties": false,
  "properties": {
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entity" }
    }
  },
  "$defs": {
    "entity": {
      "type": "object",
      "required": ["name", "description", "fields"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "PascalCase entity name.",
          "pattern": "^[A-Z][a-zA-Z0-9]+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/field" }
        },
        "business_rules": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^BR-\\d{3}$"
          },
          "description": "IDs of business rules that govern this entity."
        }
      }
    },
    "field": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "camelCase field name.",
          "pattern": "^[a-z][a-zA-Z0-9]*$"
        },
        "type": {
          "type": "string",
          "enum": [
            "string", "text", "integer", "decimal", "boolean", "uuid",
            "date", "datetime", "timestamp",
            "enum", "json", "reference"
          ]
        },
        "primary": {
          "type": "boolean",
          "default": false
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "unique": {
          "type": "boolean",
          "default": false
        },
        "default": {
          "description": "Default value - literal or keyword (e.g. \"now\", \"uuid\")."
        },
        "enum_values": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Valid values when type is enum."
        },
        "ref_entity": {
          "type": "string",
          "description": "Target entity name when type is reference."
        },
        "ref_field": {
          "type": "string",
          "description": "Target field name when type is reference."
        },
        "max_length": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum character length for string fields."
        },
        "precision": {
          "type": "integer",
          "minimum": 1,
          "description": "Total digits for decimal fields."
        },
        "scale": {
          "type": "integer",
          "minimum": 0,
          "description": "Decimal places for decimal fields."
        }
      }
    }
  }
}
