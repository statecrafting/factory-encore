{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "use-cases.schema.json",
  "title": "Use Cases - Stage 1 Output",
  "description": "Every action a user or system performs, extracted from business documents.",
  "type": "object",
  "required": ["use_cases"],
  "additionalProperties": false,
  "properties": {
    "use_cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/use_case" }
    }
  },
  "$defs": {
    "use_case": {
      "type": "object",
      "required": ["id", "name", "actor", "preconditions", "main_flow", "postconditions"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^UC-\\d{3}$",
          "description": "Stable identifier in UC-nnn format."
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "actor": {
          "type": "string",
          "minLength": 1,
          "description": "The role or system that initiates this action."
        },
        "preconditions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Conditions that must be true before the flow begins."
        },
        "main_flow": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Ordered steps of the happy-path flow."
        },
        "postconditions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Conditions that are true after successful completion."
        },
        "related_entities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Entity names involved in this use case."
        },
        "business_rules": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^BR-\\d{3}$"
          },
          "description": "Business rules enforced during this use case."
        }
      }
    }
  }
}
